@model List<FacultyMonitoringSystem.Models.TimetableEntry>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">

    <div class="card shadow p-4">

        <h3 class="text-center mb-3">Faculty Timetable</h3>

        <!-- INFO -->
        <div class="text-center mb-4">
            <h5>@ViewBag.Name</h5>
            <p>@ViewBag.Department</p>

            <p>
                Status:
                @if (ViewBag.Status == "Approved")
                {
                    <span class="badge bg-success">Approved</span>
                }
                else if (ViewBag.Status == "Rejected")
                {
                    <span class="badge bg-danger">Rejected</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Pending</span>
                }
            </p>
        </div>

        @{
            var days = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
            var slots = new[]
            {
                "09:30-10:30",
                "10:30-11:30",
                "11:30-12:30",
                "12:30-13:30",
                "13:30-14:30",
                "14:30-15:30",
                "15:30-16:30"
            };
        }

        <table class="table table-bordered text-center">

            <thead class="table-dark">
                <tr>
                    <th>Day</th>
                    @foreach (var slot in slots)
                    {
                        <th>@slot</th>
                    }
                </tr>
            </thead>

            <tbody>
                @foreach (var day in days)
                {
                    <tr>
                        <td><b>@day</b></td>

                        @foreach (var slot in slots)
                        {
                            var timeParts = slot.Split('-');
                            var start = TimeSpan.Parse(timeParts[0]);
                            var end = TimeSpan.Parse(timeParts[1]);

                            var entry = Model.FirstOrDefault(e =>
                                e.Day == day &&
                                e.StartTime == start &&
                                e.EndTime == end
                            );

                            <td>
                                @if (entry != null)
                                {
                                    <div>
                                        <b>@entry.Subject</b><br />
                                        <small>@entry.Room</small>
                                    </div>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>

        </table>

        <div class="text-center mt-4">
            <a href="/Principal/Search" class="btn btn-secondary">⬅ Back</a>
        </div>

    </div>

</div>