@model dynamic

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">

    <h3 class="text-center mb-4">Principal Panel</h3>
    

    <table class="table table-bordered text-center">

        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Department</th>
                <th>Semester</th>
                <th>Academic Year</th>
                <th>Status</th>
                <th>View</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Department</td>
                    <td>@item.Semester</td>
                    <td>@item.AcademicYear</td>
                    <td>
                        <span class="badge bg-@(item.Status == "Approved" ? "success" : item.Status == "Rejected" ? "danger" : "warning")">
                            @item.Status
                        </span>
                    </td>
                    <td>
                        <a href="/Principal/ViewTimetable/@item.TeacherId" class="btn btn-primary btn-sm">
                            View Timetable
                        </a>
                    </td>
                </tr>
            }

        </tbody>

    </table>

</div>