@{
    ViewData["Title"] = "Search Teacher Location";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">

    <div class="card p-4 col-md-6 mx-auto shadow">

        <h3 class="text-center mb-4">Find Teacher Location</h3>

        <!-- 🔍 SEARCH FORM -->
        <form method="post">

            <!-- Teacher Name -->
            <input type="text" name="teacherName"
                   class="form-control mb-3"
                   placeholder="Enter Teacher Name" required />

            <!-- Department Dropdown -->
            <select name="department" class="form-control mb-3" required>
                <option value="">Select Department</option>
                <option value="BCA">BCA</option>
                <option value="BBA">BBA</option>
                <option value="MBA">MBA</option>
                <option value="BPharm">BPharm</option>
                <option value="MPharm">MPharm</option>
                <option value="BSc">BSc</option>
                <option value="MSc">MSc</option>
            </select>

            <!-- Search Button -->
            <button type="submit" class="btn btn-primary w-100">
                Search
            </button>

        </form>

        <hr />

        <!-- ✅ RESULT SECTION -->
        @if (ViewBag.Result != null)
        {
            <div class="alert alert-success text-center mt-3">
                <h5>
                    <b>@ViewBag.Result.Teacher</b><br />
                    is currently in <b>@ViewBag.Result.Room</b><br />
                    teaching <b>@ViewBag.Result.Subject</b>
                </h5>
            </div>
        }
        else if (Context.Request.Method == "POST")
        {
            <div class="alert alert-danger text-center mt-3">
                Teacher not in class right now
            </div>
        }

    </div>

</div>