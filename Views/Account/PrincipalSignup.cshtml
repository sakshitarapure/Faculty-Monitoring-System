<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">
    <div class="card shadow p-4 col-md-4 mx-auto">

        <h3 class="text-center text-dark">Signup as Principal</h3>

        <form method="post" action="/Account/Register">

            <input type="text" name="Name" placeholder="Full Name" class="form-control mb-3" required />

            <input type="email" name="Email" placeholder="Email" class="form-control mb-3" required />

            <input type="password" name="Password" placeholder="Password" class="form-control mb-3" required />

            <!-- ✅ FIX: Default department -->
            <input type="hidden" name="Department" value="Administration" />

            <input type="hidden" name="Role" value="Principal" />

            <button class="btn btn-dark w-100">Register as Principal</button>
        </form>

        <p class="text-center mt-3">
            Already have account? <a href="/Account/Login">Login</a>
        </p>

    </div>
</div>