<div class="container mt-5">

    <div class="card shadow p-4 col-md-6 mx-auto">

        <h3 class="text-center mb-4">Review Timetable</h3>

        <form method="post" action="/HOD/Review">

            <!-- ✅ IMPORTANT -->
            <input type="hidden" name="teacherId" value="@ViewBag.TeacherId" />

            <!-- INFO -->
            <div class="mb-3 text-center">
                <p><b>👩‍🏫 Teacher:</b> @ViewBag.Name</p>
                <p><b>🏫 Department:</b> @ViewBag.Department</p>
            </div>

            <hr />

            <!-- STATUS -->
            <label class="fw-bold">Select Status:</label>
            <select name="status" class="form-control mb-3" required>
                <option value="">-- Select --</option>
                <option value="Approved">Approve</option>
                <option value="Rejected">Reject</option>
            </select>

            <!-- REMARKS -->
            <label class="fw-bold">Remarks:</label>
            <textarea name="remarks"
                      class="form-control mb-4"
                      placeholder="Write comments..."
                      required></textarea>

            <!-- BUTTONS -->
            <div class="d-flex justify-content-between">
                <a href="/HOD/Dashboard" class="btn btn-secondary">⬅ Back</a>
                <button type="submit" class="btn btn-success">Submit ✔</button>
            </div>

        </form>

    </div>

</div>